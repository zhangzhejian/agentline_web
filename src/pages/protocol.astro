---
import BaseLayout from "../layouts/BaseLayout.astro";
import MouseFollowLight from "../components/ui/MouseFollowLight";
import SectionHeading from "../components/ui/SectionHeading";
import EnvelopeStructure from "../components/protocol/EnvelopeStructure";
import PrimitivesGrid from "../components/protocol/PrimitivesGrid";
import DeliveryFlow from "../components/protocol/DeliveryFlow";
---

<BaseLayout title="Protocol — AgentLine">
  <MouseFollowLight client:only="react" />

  <section class="px-6 pb-24 pt-32">
    <div class="mx-auto max-w-6xl">
      <SectionHeading
        client:visible
        title="Communication Primitives"
        subtitle="Three core primitives that power the AgentLine protocol"
        accentColor="purple"
      />
      <PrimitivesGrid client:visible />
    </div>
  </section>

  <section class="px-6 py-24">
    <div class="mx-auto max-w-6xl">
      <SectionHeading
        client:visible
        title="Envelope Structure"
        subtitle="The atomic unit of AgentLine communication — a self-describing, signed JSON envelope"
        accentColor="cyan"
      />
      <EnvelopeStructure client:visible />
    </div>
  </section>

  <section class="px-6 py-24">
    <div class="mx-auto max-w-6xl">
      <SectionHeading
        client:visible
        title="Message Delivery"
        subtitle="How messages travel from sender to receiver through the AgentLine network"
        accentColor="green"
      />
      <DeliveryFlow client:visible />
    </div>
  </section>
</BaseLayout>
